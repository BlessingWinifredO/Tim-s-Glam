rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Admin check: email must match the whitelisted admin addresses.
    // Update these emails if your admin email changes.
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'winniewizzyb@gmail.com' ||
        request.auth.token.email == 'admin@tims-glam.com'
      );
    }

    // Owner check: the requesting user owns this document by UID.
    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // -------------------------------------------------------
    // Products — public read, admin write only
    // -------------------------------------------------------
    match /products/{productId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // -------------------------------------------------------
    // Orders — owner or admin read, authenticated write
    // (checkout creates orders while logged in)
    // -------------------------------------------------------
    match /orders/{orderId} {
      allow read: if isAdmin() || (request.auth != null && request.auth.uid == resource.data.userId);
      allow create: if request.auth != null;
      allow update, delete: if isAdmin();
    }

    // -------------------------------------------------------
    // App Settings — public read (used in checkout/shop),
    // admin write only
    // -------------------------------------------------------
    match /appSettings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // -------------------------------------------------------
    // Blog posts — public read for published, admin write
    // -------------------------------------------------------
    match /blogPosts/{postId} {
      allow read: if resource.data.status == 'published' || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    // -------------------------------------------------------
    // Users — owner or admin read/write
    // -------------------------------------------------------
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if request.auth != null && request.auth.uid == userId;
      allow delete: if isOwner(userId) || isAdmin();
      // Normal updates are owner-only.
      // Unauthenticated emailVerified flip is allowed only for that field.
      allow update: if isOwner(userId)
        || isAdmin()
        || (
          request.auth == null
          && resource.data.emailVerified != true
          && request.resource.data.diff(resource.data).changedKeys().hasOnly(['emailVerified'])
          && request.resource.data.emailVerified == true
        );
    }

    // -------------------------------------------------------
    // Verification codes — write by anyone (unauthenticated
    // signup needs to store code), read only by admin or the
    // matching authenticated user.
    // Client-side OTP comparison is kept for now; the code
    // is also verified server-side in /api/send-auth-code.
    // -------------------------------------------------------
    match /verificationCodes/{emailKey} {
      allow write: if true;
      allow read: if isAdmin()
        || (request.auth != null && request.auth.token.email == emailKey);
    }

    // -------------------------------------------------------
    // Reset codes — same pattern as verificationCodes
    // -------------------------------------------------------
    match /resetCodes/{emailKey} {
      allow write: if true;
      allow read: if isAdmin()
        || (request.auth != null && request.auth.token.email == emailKey);
    }

    // -------------------------------------------------------
    // Newsletter subscribers — admin read/write only
    // (subscribe endpoint is server-side via Admin SDK)
    // -------------------------------------------------------
    match /newsletterSubscribers/{docId} {
      allow read, write: if isAdmin();
    }

    // -------------------------------------------------------
    // Email logs — admin read only, server-side write
    // -------------------------------------------------------
    match /emailLogs/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // -------------------------------------------------------
    // Cart / wishlist (if ever persisted) — owner only
    // -------------------------------------------------------
    match /carts/{userId} {
      allow read, write: if isOwner(userId);
    }
    match /wishlists/{userId} {
      allow read, write: if isOwner(userId);
    }

    // -------------------------------------------------------
    // Contact messages — anyone can submit, admin reads
    // -------------------------------------------------------
    match /contactMessages/{docId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // -------------------------------------------------------
    // Deny everything else by default
    // -------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
